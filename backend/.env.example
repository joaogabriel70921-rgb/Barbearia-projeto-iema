# Copie este arquivo para .env e preencha os valores.
# O .env NÃO deve ser versionado (já está no .gitignore).

# Porta da API
PORT=3000

# Conexão do MongoDB (Atlas ou local)
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/barbearia

# Segredo para assinar os tokens JWT (use um valor forte e secreto)
JWT_SECRET=troque-por-um-segredo-forte

# URL(s) do frontend — usado no CORS e nos links dos emails.
# Aceita várias separadas por vírgula. Ex.: http://localhost:5173,https://seusite.com
FRONTEND_URL=http://localhost:5173

# Email do admin (dono). Os seeds usam este valor; se vazio, usa admin@barbearia.com
ADMIN_EMAIL=

# --- Email (SMTP) — opcional ---
# Necessário para enviar o código de verificação de cadastro e a recuperação de senha.
# Com Gmail: ative a verificação em 2 etapas e gere uma "Senha de App" (16 dígitos).
# Use a porta 587 (STARTTLS).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_FROM=Barbearia IEMA <seuemail@gmail.com>
