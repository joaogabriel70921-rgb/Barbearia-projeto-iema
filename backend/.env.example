# Copie este arquivo para .env e preencha os valores.
# O .env NÃO deve ser versionado (já está no .gitignore).

# Porta da API
PORT=3000

# Conexão do MongoDB (Atlas ou local)
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/barbearia

# Segredo para assinar os tokens JWT (use um valor forte e secreto)
JWT_SECRET=troque-por-um-segredo-forte

# URL(s) do frontend — usado no CORS e nos links dos emails.
# Aceita várias separadas por vírgula. Ex.: http://localhost:5173,https://seusite.com
FRONTEND_URL=http://localhost:5173

# Email do admin (dono). Os seeds usam este valor; se vazio, usa admin@barbearia.com
ADMIN_EMAIL=

# --- Email ---
# Usado no código de verificação de cadastro e na recuperação de senha.
# O código usa a API (Brevo) se BREVO_API_KEY existir; senão, cai no SMTP (Gmail).

# Provedor 1: API HTTP (Brevo) — RECOMENDADO em produção.
# Envia por HTTPS (porta 443), funcionando em hosts que bloqueiam SMTP de saída
# (ex.: Render no plano gratuito). Crie a conta em https://www.brevo.com,
# verifique um remetente (Senders) e gere a chave em SMTP & API > API Keys.
# O remetente usado vem de EMAIL_FROM (ou de BREVO_SENDER_EMAIL, se definido).
BREVO_API_KEY=
# Opcionais (sobrescrevem o que vem de EMAIL_FROM):
# BREVO_SENDER_EMAIL=seuemail@gmail.com
# BREVO_SENDER_NAME=Barbearia IEMA

# Provedor 2: SMTP (Gmail) — usado no local quando não há BREVO_API_KEY.
# Com Gmail: ative a verificação em 2 etapas e gere uma "Senha de App" (16 dígitos).
# Use a porta 587 (STARTTLS). Obs.: SMTP NÃO funciona no Render free (use o Brevo lá).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app
EMAIL_FROM=Barbearia IEMA <seuemail@gmail.com>
